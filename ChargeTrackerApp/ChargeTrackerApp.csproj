<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>annotations</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>ChargeTrackerApp</AssemblyName>
    <RootNamespace>ChargeTrackerApp</RootNamespace>
    <Version>1.0.0</Version>
    <Product>Charge Tracker</Product>
    <Company>Charge Tracker</Company>
    <Description>Applicazione per la gestione delle ricariche di tutti i dispositivi elettronici di casa.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="LiteDB" Version="5.0.21" />
    <PackageReference Include="QRCoder" Version="1.6.0" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="System.Drawing.Common" Version="8.0.8" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Accessibility" />
  </ItemGroup>

</Project>
