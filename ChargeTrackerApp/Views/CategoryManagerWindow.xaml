<Window x:Class="ChargeTrackerApp.Views.CategoryManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ChargeTrackerApp.Helpers"
        Title="Gestisci categorie" Height="520" Width="380"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Categorie dispositivo" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Eliminando una categoria, i dispositivi che la usano vengono riassegnati ad 'Altro'. La categoria 'Altro' non può essere eliminata."
                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="NewCategoryBox" Grid.Column="0" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Content="＋ Aggiungi" Style="{StaticResource PrimaryButtonStyle}" Click="AddCategory_Click"/>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CategoriesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBackgroundHoverBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0">
                                            <Run Text="{Binding DeviceCount, Mode=OneWay}"/>
                                            <Run Text="dispositivi"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="&#xE74D;" Style="{StaticResource DangerIconButtonStyle}"
                                            FontFamily="Segoe MDL2 Assets"
                                            Click="DeleteCategory_Click" Tag="{Binding Name}"
                                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="3" Content="Chiudi" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" Width="100" Margin="0,16,0,0" Click="Close_Click"/>
    </Grid>
</Window>
