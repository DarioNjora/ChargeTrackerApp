<Window x:Class="ChargeTrackerApp.Views.ManageLocationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestisci posizioni" Height="440" Width="380"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Posizioni / stanze" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Eliminare una posizione la rimuove da tutti i dispositivi che la usano (i dispositivi non vengono eliminati, restano solo senza posizione)."
                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LocationsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBackgroundHoverBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0">
                                            <Run Text="{Binding DeviceCount, Mode=OneWay}"/>
                                            <Run Text="dispositivi"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="&#xE74D;" Style="{StaticResource DangerIconButtonStyle}"
                                            FontFamily="Segoe MDL2 Assets"
                                            Click="DeleteLocation_Click" Tag="{Binding Name}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="1" Text="Nessuna posizione ancora assegnata a un dispositivo."
                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0"
                   x:Name="EmptyText" Visibility="Collapsed"/>

        <Button Grid.Row="2" Content="Chiudi" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" Width="100" Margin="0,16,0,0" Click="Close_Click"/>
    </Grid>
</Window>
